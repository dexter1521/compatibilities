@baseUrl = http://localhost:8080
@email = admin@sharkmotors.local
@password = Admin123!
@accessToken = REEMPLAZAR_ACCESS
@refreshToken = REEMPLAZAR_REFRESH

### Login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Me
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}

### Refresh
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Search
GET {{baseUrl}}/api/v1/search?q=balata&limit=10
Authorization: Bearer {{accessToken}}

### Productos List
GET {{baseUrl}}/api/v1/productos?page=1&per_page=20
Authorization: Bearer {{accessToken}}

### Motocicletas List
GET {{baseUrl}}/api/v1/motocicletas
Authorization: Bearer {{accessToken}}

### Piezas List
GET {{baseUrl}}/api/v1/piezas
Authorization: Bearer {{accessToken}}

### Aliases List
GET {{baseUrl}}/api/v1/aliases
Authorization: Bearer {{accessToken}}

### Compatibilidades List
GET {{baseUrl}}/api/v1/compatibilidades
Authorization: Bearer {{accessToken}}

### Confirmar compatibilidad (vendedor/admin)
PATCH {{baseUrl}}/api/v1/compatibilidades/1/confirmar
Authorization: Bearer {{accessToken}}

### Logout
POST {{baseUrl}}/api/v1/auth/logout
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Aliases Update
PUT {{baseUrl}}/api/v1/aliases/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "motocicleta_id": 1,
  "alias": "FT 150"
}
